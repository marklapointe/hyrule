   131 +         */                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                   
   132 +        return (events & (POLLIN | POLLRDNORM | POLLOUT | POLLWRNORM));                                                                                                                                                                                                                                                                                                                                                                                                                                                                                       
